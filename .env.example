# The Convex deployment URL (set by `npx convex dev`, or manually for prod).
# This is the only required variable to run the frontend.
NEXT_PUBLIC_CONVEX_URL="https://your-deployment.convex.cloud"

PAYMENT_MODE="mock"

# Required only when PAYMENT_MODE="live" (Stripe card payments).
# In Convex, set these as deployment variables: `npx convex env set STRIPE_SECRET_KEY ...`
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Public app URL (absolute links, OG metadata). No trailing slash.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
